# ══════════════════════════════════════════════════════════════
# EXAMIND — AI Agent Soal Generator
# Salin file ini menjadi .env lalu isi nilai yang sesuai
# JANGAN pernah commit file .env ke Git!
# ══════════════════════════════════════════════════════════════

# ── LLM Provider ──────────────────────────────────────────────
# Pilihan: gemini | claude
LLM_MAIN=gemini           # Dipakai oleh: Generator, Planner, Answer Key Agent

# Pilihan: groq | claude
LLM_SCORER=groq           # Dipakai oleh: Validator, Difficulty Calibrator

# Pilihan: gemini | claude
LLM_VISION=gemini         # Dipakai oleh: Image captioning saat KB ingestion

# ── API Keys ──────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Pipeline Config ───────────────────────────────────────────
VALIDATOR_THRESHOLD=75          # Skor minimum soal untuk lulus validator (0-100)
MAX_RETRY=3                     # Maksimal berapa kali soal gagal boleh di-regenerate
BATCH_SIZE=5                    # Jumlah soal per LLM call di Generator
DUPLICATE_SIMILARITY_THRESHOLD=0.85   # Cosine similarity untuk flag duplikat (0.0-1.0)

# ── Paths ─────────────────────────────────────────────────────
KB_PATH=./knowledge_base
ASSETS_PATH=./assets
CHROMA_PATH=./db/chroma
SQLITE_PATH=./db/sqlite/soal_output.db
